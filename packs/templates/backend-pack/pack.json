{
  "id": "yunque.pack.example",
  "name": "Example Pack",
  "version": "0.1.0",
  "description": "可选后端能力包模板：通过 Pack Runtime 注册路由、同步前端入口，并暴露轻量 SDK 调用面。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "disabled",
  "backend": {
    "capabilities": [
      "example.ping"
    ],
    "routes": [
      "/v1/example-pack/ping"
    ],
    "permissions": [
      "example:read"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/example-pack/ping",
        "description": "Example pack health/readiness endpoint."
      }
    ]
  },
  "frontend": {
    "menus": [
      {
        "key": "example-pack",
        "label": "示例包",
        "path": "/packs/example",
        "icon": "package",
        "order": 120
      }
    ],
    "routes": [
      {
        "path": "/packs/example",
        "component": "example/ExamplePackPage",
        "title": "示例包"
      }
    ],
    "assets": {
      "type": "builtin",
      "entry": "example/ExamplePackPage"
    }
  },
  "sdk": {
    "typescript": "yunque-client/example-pack"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "template": "backend-pack",
    "sync": "backend-registry-drives-frontend"
  },
  "distribution": {
    "manifestUrl": "https://packs.yunque.local/example-pack/pack.json",
    "packageUrl": "https://packs.yunque.local/example-pack/example-pack-0.1.0.tgz",
    "frontendUrl": "https://packs.yunque.local/example-pack/frontend/remoteEntry.js",
    "sha256": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
    "sizeBytes": 4096
  }
}
