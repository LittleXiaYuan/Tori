{
  "id": "yunque.pack.files",
  "name": "Files (产物文件)",
  "version": "0.1.0",
  "description": "产物文件能力：列出、预览和下载云雀生成的输出文件。默认预装，由 Chat 产物区和任务结果界面调用。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "enabled",
  "backend": {
    "capabilities": [
      "files.list",
      "files.preview",
      "files.download"
    ],
    "routes": [
      "/api/files",
      "/api/files/preview",
      "/api/files/download"
    ],
    "permissions": [
      "files:read",
      "filesystem:read"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/api/files",
        "description": "List generated output files below the configured output directory."
      },
      {
        "method": "GET",
        "path": "/api/files/preview",
        "description": "Preview a generated output file with path traversal protection."
      },
      {
        "method": "GET",
        "path": "/api/files/download",
        "description": "Download a generated output file with path traversal protection."
      }
    ]
  },
  "frontend": {
    "menus": [],
    "assets": {
      "type": "builtin"
    }
  },
  "sdk": {
    "typescript": "yunque-client/files"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "group": "work",
    "phase": "A4",
    "preload": "true",
    "note": "Natively owns /api/files* through Pack Runtime. It only resolves paths inside the configured output directory.",
    "usability": "infrastructure",
    "primaryActionLabel": "查看最近产物",
    "primaryActionPath": "/chat?q=%E5%88%97%E5%87%BA%E6%88%91%E6%9C%80%E8%BF%91%E7%94%9F%E6%88%90%E7%9A%84%E6%96%87%E4%BB%B6%EF%BC%8C%E5%B9%B6%E5%91%8A%E8%AF%89%E6%88%91%E5%93%AA%E4%BA%9B%E5%8F%AF%E4%BB%A5%E9%A2%84%E8%A7%88%E3%80%81%E4%B8%8B%E8%BD%BD%E6%88%96%E7%BB%A7%E7%BB%AD%E5%A4%84%E7%90%86",
    "usageSurface": "Chat 产物区、任务结果页、文件预览与下载入口",
    "example1": "在 Chat 里列出云雀生成的文件。",
    "example2": "预览或下载任务输出的报告、表格和页面。",
    "example3": "把产物继续交给云雀处理、分享或沉淀。"
  },
  "status": "beta"
}
