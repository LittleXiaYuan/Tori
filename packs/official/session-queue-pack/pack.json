{
  "id": "yunque.pack.session-queue",
  "name": "Session Queue (会话任务队列)",
  "version": "0.1.0",
  "description": "会话任务队列：查看各会话的待执行任务，按会话查看队列快照，并取消尚未开始的排队任务。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "enabled",
  "backend": {
    "capabilities": [
      "queue.read",
      "queue.cancel"
    ],
    "routes": [
      "/v1/sessions/queue",
      "/v1/sessions/queue/cancel"
    ],
    "permissions": [
      "queue:read",
      "queue:write"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/sessions/queue",
        "description": "List all session queues or inspect one session queue with ?id=."
      },
      {
        "method": "POST",
        "path": "/v1/sessions/queue/cancel",
        "description": "Cancel a queued task for a session."
      }
    ]
  },
  "frontend": {
    "menus": [],
    "assets": {
      "type": "builtin"
    }
  },
  "sdk": {
    "typescript": "yunque-client/session-queue"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "group": "work",
    "phase": "A3",
    "preload": "true",
    "note": "Natively owns /v1/sessions/queue and /v1/sessions/queue/cancel through the Pack Runtime gate."
  },
  "status": "beta"
}
