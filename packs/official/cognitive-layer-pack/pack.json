{
  "id": "yunque.pack.cognitive-layer",
  "name": "Cognitive Layer Pack",
  "version": "0.1.0",
  "description": "云雀认知层总开关：记忆/反思/做梦/自进化可一键热启停。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "enabled",
  "backend": {
    "capabilities": [
      "cognitive_layer.status",
      "cognitive_layer.toggle"
    ],
    "routes": [
      "/v1/cognitive-layer"
    ],
    "permissions": [
      "cognitive_layer:read",
      "cognitive_layer:write"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/cognitive-layer",
        "description": "Read whether the cognitive layer is currently enabled."
      },
      {
        "method": "POST",
        "path": "/v1/cognitive-layer",
        "description": "Hot-toggle the whole cognitive layer (memory/reflection/dreaming/evolution) at runtime, no restart."
      }
    ]
  },
  "sdk": {
    "typescript": "yunque-client/cognitive-layer"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "sync": "backend-registry-drives-runtime",
    "descriptionStyle": "one-line-plus-three-examples",
    "example1": "开启或关闭记忆、反思、做梦与自进化相关能力。",
    "example2": "在 Cogni 页面确认认知层是否正在参与上下文召回。",
    "example3": "把认知层作为后台能力交给对话和任务自动调用。",
    "usability": "infrastructure",
    "primaryActionLabel": "查看认知能力",
    "primaryActionPath": "/cognis",
    "usageSurface": "Cogni、记忆、反思与夜间学习状态"
  },
  "status": "beta"
}
