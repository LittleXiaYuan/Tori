{
  "id": "yunque.pack.backup",
  "name": "Backup Pack",
  "version": "0.1.0",
  "description": "本地数据恢复与迁移的可选能力包。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "enabled",
  "backend": {
    "capabilities": [
      "backup.info",
      "backup.export",
      "backup.import"
    ],
    "routes": [
      "/v1/backup/info",
      "/v1/backup/export",
      "/v1/backup/import"
    ],
    "permissions": [
      "backup:read",
      "backup:write"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/backup/info",
        "description": "Read backup pack runtime status."
      },
      {
        "method": "GET",
        "path": "/v1/backup/export",
        "description": "Export a backup archive."
      },
      {
        "method": "POST",
        "path": "/v1/backup/import",
        "description": "Import backup payload data."
      }
    ]
  },
  "frontend": {
    "menus": [
      {
        "key": "backup",
        "label": "备份恢复",
        "path": "/packs/backup",
        "icon": "archive",
        "order": 90
      }
    ],
    "routes": [
      {
        "path": "/packs/backup",
        "component": "backup/BackupPage",
        "title": "备份恢复"
      }
    ],
    "assets": {
      "type": "builtin",
      "entry": "backup/BackupPage"
    }
  },
  "sdk": {
    "typescript": "yunque-client/backup"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "example": "true",
    "sync": "backend-registry-drives-frontend",
    "descriptionStyle": "one-line-plus-three-examples",
    "example1": "查看当前备份状态与存储位置。",
    "example2": "导出一份可迁移的本地数据归档。",
    "example3": "导入归档并保留可回滚恢复记录。"
  },
  "status": "beta"
}
