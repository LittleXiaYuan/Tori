{
  "id": "yunque.pack.emotion",
  "name": "Emotion (情绪记录)",
  "version": "0.1.0",
  "description": "情绪记录能力：查询情绪历史，并管理不同平台的表情贴纸映射。默认预装，由聊天、渠道和记忆界面调用。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "enabled",
  "backend": {
    "capabilities": [
      "emotion.history.read",
      "emotion.stickers.read",
      "emotion.stickers.write"
    ],
    "routes": [
      "/v1/emotion/stickers",
      "/v1/emotion/history"
    ],
    "permissions": [
      "emotion:read",
      "emotion:write",
      "memory:read"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/emotion/stickers",
        "description": "Read sticker mappings for emotion suggestions."
      },
      {
        "method": "PUT",
        "path": "/v1/emotion/stickers",
        "description": "Create or update sticker mappings."
      },
      {
        "method": "DELETE",
        "path": "/v1/emotion/stickers",
        "description": "Delete sticker mappings."
      },
      {
        "method": "GET",
        "path": "/v1/emotion/history",
        "description": "Query emotion history and summary."
      }
    ]
  },
  "frontend": {
    "menus": [],
    "assets": {
      "type": "builtin"
    }
  },
  "sdk": {
    "typescript": "yunque-client/emotion"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "group": "cogni",
    "phase": "A4",
    "preload": "true",
    "note": "Natively owns /v1/emotion/* through Pack Runtime. It exposes history and sticker-map access without changing Cogni decisions."
  },
  "status": "beta"
}
