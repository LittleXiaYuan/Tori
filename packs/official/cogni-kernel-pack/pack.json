{
  "id": "yunque.pack.cogni-kernel",
  "name": "Cogni Kernel Pack",
  "version": "0.1.0",
  "description": "声明式 Cogni 运行治理的可选认知内核能力包。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "enabled",
  "backend": {
    "capabilities": [
      "cognis.registry",
      "cognis.reload",
      "cognis.traces",
      "cognis.health",
      "cognis.alerts",
      "cognis.verify",
      "cognis.generate",
      "cognis.bundle",
      "cognis.workflows",
      "cognis.experience",
      "cognis.evolution",
      "cognis.federation",
      "cognis.economics",
      "cognis.runtime.pack_state",
      "cognis.runtime.loop_gate"
    ],
    "routes": [
      "/v1/cognis",
      "/v1/cognis/",
      "/v1/cognis/runtime/pack-state"
    ],
    "permissions": [
      "cognis:read",
      "cognis:write",
      "cognis:evolve",
      "cognis:federate"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/cognis",
        "description": "List Cogni declarations and health summaries."
      },
      {
        "method": "POST",
        "path": "/v1/cognis",
        "description": "Create an inline Cogni declaration."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/",
        "description": "Read Cogni detail, traces, health, workflows, experience, evolution, federation or economics sub-resources."
      },
      {
        "method": "POST",
        "path": "/v1/cognis/",
        "description": "Reload, enable, disable, verify, generate, import, evolve, record experience, run workflows or update federation sub-resources."
      },
      {
        "method": "DELETE",
        "path": "/v1/cognis/",
        "description": "Remove a Cogni declaration."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/runtime/pack-state",
        "description": "Read live Cogni runtime-loop and pack-state gate status."
      }
    ]
  },
  "frontend": {
    "menus": [
      {
        "key": "cognis",
        "label": "智体内核",
        "path": "/packs/cognis",
        "icon": "brain-circuit",
        "order": 80
      }
    ],
    "routes": [
      {
        "path": "/packs/cognis",
        "component": "cognis/CogniKernelPackPage",
        "title": "智体内核"
      }
    ],
    "assets": {
      "type": "builtin",
      "entry": "cognis/CogniKernelPackPage"
    }
  },
  "sdk": {
    "typescript": "yunque-client/cognis"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "blueprint": "doc/PACK-RUNTIME-BLUEPRINT.md",
    "stage": "runtime-loop-pack-state-gate",
    "sync": "backend-registry-drives-frontend",
    "runtimeArtifact": "cogni-runtime-pack-state.json",
    "descriptionStyle": "one-line-plus-three-examples",
    "example1": "列出、重载并校验 Cogni Declaration。",
    "example2": "查看 Cogni trace、健康状态和告警。",
    "example3": "导出 bundle 并检查经验/经济/联邦状态。"
  },
  "status": "stable"
}
