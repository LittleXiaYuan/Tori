{
  "id": "yunque.pack.cogni-kernel",
  "name": "Cogni Kernel Pack",
  "version": "0.1.0",
  "description": "声明式 Cogni 运行治理的可选认知内核能力包。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "enabled",
  "backend": {
    "capabilities": [
      "cognis.registry",
      "cognis.reload",
      "cognis.traces",
      "cognis.health",
      "cognis.alerts",
      "cognis.verify",
      "cognis.generate",
      "cognis.bundle",
      "cognis.workflows",
      "cognis.experience",
      "cognis.evolution",
      "cognis.federation",
      "cognis.economics",
      "cognis.runtime.pack_state",
      "cognis.runtime.loop_gate"
    ],
    "routes": [
      "/v1/cognis",
      "/v1/cognis/",
      "/v1/cognis/reload",
      "/v1/cognis/traces",
      "/v1/cognis/stats",
      "/v1/cognis/health",
      "/v1/cognis/alerts",
      "/v1/cognis/alerts/scan",
      "/v1/cognis/verify",
      "/v1/cognis/generate",
      "/v1/cognis/export",
      "/v1/cognis/import",
      "/v1/cognis/evolution",
      "/v1/cognis/federation",
      "/v1/cognis/federation/peers",
      "/v1/cognis/federation/discover",
      "/v1/cognis/economics",
      "/v1/cognis/route",
      "/v1/cognis/runtime/pack-state"
    ],
    "permissions": [
      "cognis:read",
      "cognis:write",
      "cognis:evolve",
      "cognis:federate"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/cognis",
        "description": "List Cogni declarations with health summaries."
      },
      {
        "method": "POST",
        "path": "/v1/cognis",
        "description": "Create an inline Cogni declaration."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/",
        "description": "Read one Cogni declaration or its sub-resources."
      },
      {
        "method": "POST",
        "path": "/v1/cognis/",
        "description": "Run Cogni mutations such as reload, enable, disable, verify, generate, import, evolve, experience record, workflow run, federation update, or routing."
      },
      {
        "method": "DELETE",
        "path": "/v1/cognis/",
        "description": "Remove one Cogni declaration."
      },
      {
        "method": "POST",
        "path": "/v1/cognis/reload",
        "description": "Reload Cogni declarations from disk."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/traces",
        "description": "List recent per-turn Cogni evaluation traces."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/stats",
        "description": "Read Cogni trace activation statistics."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/health",
        "description": "Read health metrics for all recently observed Cogni declarations."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/alerts",
        "description": "List Cogni sentinel alerts."
      },
      {
        "method": "POST",
        "path": "/v1/cognis/alerts/scan",
        "description": "Run a Cogni sentinel alert scan."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/verify",
        "description": "Verify all Cogni declarations."
      },
      {
        "method": "POST",
        "path": "/v1/cognis/verify",
        "description": "Verify all Cogni declarations."
      },
      {
        "method": "POST",
        "path": "/v1/cognis/generate",
        "description": "Generate a Cogni declaration from a natural-language description."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/export",
        "description": "Export Cogni declarations as a bundle."
      },
      {
        "method": "POST",
        "path": "/v1/cognis/export",
        "description": "Export Cogni declarations as a bundle."
      },
      {
        "method": "POST",
        "path": "/v1/cognis/import",
        "description": "Import a Cogni bundle and persist accepted declarations."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/evolution",
        "description": "List Cogni evolution experiments."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/federation",
        "description": "Read Cogni federation status."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/federation/peers",
        "description": "List Cogni federation peers."
      },
      {
        "method": "POST",
        "path": "/v1/cognis/federation/peers",
        "description": "Add a Cogni federation peer."
      },
      {
        "method": "POST",
        "path": "/v1/cognis/federation/discover",
        "description": "Discover remote Cogni federation skills."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/economics",
        "description": "Read Cogni economics and cost summary."
      },
      {
        "method": "POST",
        "path": "/v1/cognis/route",
        "description": "Route a message through Cogni candidates."
      },
      {
        "method": "GET",
        "path": "/v1/cognis/runtime/pack-state",
        "description": "Read live Cogni runtime-loop and pack-state gate status."
      }
    ]
  },
  "frontend": {
    "menus": [],
    "routes": [
      {
        "path": "/packs/cognis",
        "component": "cognis/CogniKernelPackPage",
        "title": "智体内核"
      }
    ],
    "assets": {
      "type": "builtin",
      "entry": "cognis/CogniKernelPackPage"
    }
  },
  "sdk": {
    "typescript": "yunque-client/cognis"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "blueprint": "docs/spec/pack-runtime-blueprint.md",
    "stage": "runtime-loop-pack-state-gate",
    "sync": "backend-registry-drives-frontend",
    "runtimeArtifact": "cogni-runtime-pack-state.json",
    "descriptionStyle": "one-line-plus-three-examples",
    "usability": "infrastructure",
    "primaryActionLabel": "查看 Cogni 管理",
    "primaryActionPath": "/cognis",
    "usageSurface": "Cogni 管理页、Planner 选择 Cogni、运行轨迹、健康检查与能力包状态门禁",
    "example1": "列出、重载并校验 Cogni Declaration。",
    "example2": "查看 Cogni trace、健康状态和告警。",
    "example3": "导出 bundle 并检查经验/经济/联邦状态。"
  },
  "status": "stable"
}
