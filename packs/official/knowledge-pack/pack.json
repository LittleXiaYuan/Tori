{
  "id": "yunque.pack.knowledge",
  "name": "Knowledge (知识库)",
  "version": "0.1.0",
  "description": "知识库面：来源管理、导入、检索（RAG）。默认预装的核心能力，可在能力包中心关闭。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "enabled",
  "backend": {
    "capabilities": [
      "knowledge.search",
      "knowledge.ingest"
    ],
    "routes": [
      "/v1/knowledge/search",
      "/v1/knowledge/sources",
      "/v1/knowledge/stats",
      "/v1/knowledge/upload",
      "/v1/knowledge/ingest",
      "/v1/knowledge/import-url",
      "/v1/knowledge/import-repo",
      "/v1/knowledge/source",
      "/v1/knowledge/source/update"
    ],
    "permissions": [
      "knowledge:read",
      "knowledge:write"
    ]
  },
  "frontend": {
    "menus": [
      { "key": "knowledge", "label": "知识库", "path": "/knowledge", "icon": "package", "order": 61 }
    ],
    "assets": {
      "type": "builtin"
    }
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "group": "intelligence",
    "phase": "A2",
    "preload": "true",
    "usability": "actionable",
    "primaryActionLabel": "管理知识来源",
    "primaryActionPath": "/knowledge",
    "usageSurface": "知识库页、文本/文件/URL/仓库导入、RAG 检索与任务上下文",
    "descriptionStyle": "one-line-plus-three-examples",
    "example1": "上传文件、粘贴 URL 或导入仓库作为知识来源。",
    "example2": "查看每个来源的状态、更新时间和可检索内容。",
    "example3": "让 Chat 和任务在需要时召回这些知识。",
    "note": "Default-preloaded pack: in the pack model (can be disabled) but enabled out-of-box. Frontend nav stays static for now; pack-gating lands with profile removal."
  },
  "status": "beta"
}
