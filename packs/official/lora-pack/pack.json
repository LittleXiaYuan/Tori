{
  "id": "yunque.pack.lora",
  "name": "LoRA / LAA Evolution Pack",
  "version": "0.1.0",
  "description": "模型训练进化的可选成长能力包。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "disabled",
  "backend": {
    "capabilities": [
      "lora.status",
      "lora.history",
      "lora.summary",
      "lora.preview",
      "lora.trigger",
      "lora.rollback",
      "lora.evolution",
      "lora.config"
    ],
    "routes": [
      "/v1/lora/status",
      "/v1/lora/history",
      "/v1/lora/summary",
      "/v1/lora/preview",
      "/v1/lora/trigger",
      "/v1/lora/rollback",
      "/v1/lora/evolution",
      "/v1/lora/config"
    ],
    "permissions": [
      "lora:read",
      "lora:write"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/lora/status",
        "description": "Read LoRA scheduler state and active adapter."
      },
      {
        "method": "GET",
        "path": "/v1/lora/history",
        "description": "Read recent LoRA training records."
      },
      {
        "method": "GET",
        "path": "/v1/lora/summary",
        "description": "Read aggregate LoRA training metrics."
      },
      {
        "method": "GET",
        "path": "/v1/lora/preview",
        "description": "Preview usable training samples before triggering LoRA."
      },
      {
        "method": "POST",
        "path": "/v1/lora/trigger",
        "description": "Trigger a scheduler training check for the current tenant."
      },
      {
        "method": "POST",
        "path": "/v1/lora/rollback",
        "description": "Rollback to the previous adapter."
      },
      {
        "method": "GET",
        "path": "/v1/lora/evolution",
        "description": "Read LAA evolution coordinator state."
      },
      {
        "method": "GET",
        "path": "/v1/lora/config",
        "description": "Read LoRA scheduler configuration."
      },
      {
        "method": "PUT",
        "path": "/v1/lora/config",
        "description": "Replace LoRA scheduler configuration fields."
      },
      {
        "method": "PATCH",
        "path": "/v1/lora/config",
        "description": "Patch LoRA scheduler configuration fields."
      }
    ]
  },
  "frontend": {
    "menus": [
      {
        "key": "lora",
        "label": "LoRA 训练",
        "path": "/packs/lora",
        "icon": "circuit-board",
        "order": 95
      }
    ],
    "routes": [
      {
        "path": "/packs/lora",
        "component": "lora/LoRAPackPage",
        "title": "LoRA 训练"
      }
    ],
    "assets": {
      "type": "builtin",
      "entry": "lora/LoRAPackPage"
    }
  },
  "sdk": {
    "typescript": "yunque-client/lora"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "blueprint": "docs/spec/pack-runtime-blueprint.md",
    "sync": "backend-registry-drives-frontend",
    "descriptionStyle": "one-line-plus-three-examples",
    "example1": "查看训练状态、历史与数据预检摘要。",
    "example2": "触发一次 LoRA/LAA 训练或回滚。",
    "example3": "同步配置并导出进化快照。"
  },
  "status": "stable"
}
