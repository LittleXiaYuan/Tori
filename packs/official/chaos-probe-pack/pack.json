{
  "id": "yunque.pack.chaos-probe",
  "name": "Chaos Probe Pack",
  "version": "0.1.0",
  "description": "安全混沌探针与降级治理的可选运维韧性能力包。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "disabled",
  "backend": {
    "capabilities": [
      "chaos_probe.status",
      "chaos_probe.probes.list",
      "chaos_probe.probes.save",
      "chaos_probe.run",
      "chaos_probe.scheduler.plan",
      "chaos_probe.metrics.plan",
      "chaos_probe.degrade.writeback.plan",
      "chaos_probe.degrade_state.writeback",
      "chaos_probe.degrade_state.engine.plan",
      "chaos_probe.audit.append.plan",
      "chaos_probe.alert.writeback.plan",
      "chaos_probe.report.list",
      "chaos_probe.report.detail",
      "chaos_probe.evidence.export"
    ],
    "routes": [
      "/v1/chaos-probe/status",
      "/v1/chaos-probe/probes",
      "/v1/chaos-probe/run",
      "/v1/chaos-probe/scheduler/plan",
      "/v1/chaos-probe/degrade-state/writeback",
      "/v1/chaos-probe/degrade-state/engine/plan",
      "/v1/chaos-probe/reports",
      "/v1/chaos-probe/reports/",
      "/v1/chaos-probe/evidence/"
    ],
    "permissions": [
      "chaos_probe:read",
      "chaos_probe:write",
      "chaos_probe:audit"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/chaos-probe/status",
        "description": "Read chaos probe pack shell status, readiness and latest health summary."
      },
      {
        "method": "GET",
        "path": "/v1/chaos-probe/probes",
        "description": "List safe local probe definitions used by one-shot health checks."
      },
      {
        "method": "POST",
        "path": "/v1/chaos-probe/probes",
        "description": "Save or merge safe local probe definitions."
      },
      {
        "method": "POST",
        "path": "/v1/chaos-probe/run",
        "description": "Run selected safe probes and generate a health/degrade report."
      },
      {
        "method": "POST",
        "path": "/v1/chaos-probe/scheduler/plan",
        "description": "Build a non-destructive scheduler, metrics, alert, and degrade-state write-back plan for Chaos Probe."
      },
      {
        "method": "POST",
        "path": "/v1/chaos-probe/degrade-state/writeback",
        "description": "Persist the latest Chaos Probe degrade-state summary into the pack-local JSON store without mutating runtime degrade state."
      },
      {
        "method": "POST",
        "path": "/v1/chaos-probe/degrade-state/engine/plan",
        "description": "Build a plan-only runtime degrade engine handoff and audit append contract from the pack-local degrade-state store without mutating live runtime state."
      },
      {
        "method": "GET",
        "path": "/v1/chaos-probe/reports",
        "description": "List saved chaos probe reports."
      },
      {
        "method": "GET",
        "path": "/v1/chaos-probe/reports/",
        "description": "Read one saved chaos probe report by id."
      },
      {
        "method": "GET",
        "path": "/v1/chaos-probe/evidence/",
        "description": "Export a JSON evidence pack for one chaos probe report."
      }
    ]
  },
  "frontend": {
    "menus": [
      {
        "key": "chaos-probe",
        "label": "Chaos Probe",
        "path": "/packs/chaos-probe",
        "icon": "activity",
        "order": 98
      }
    ],
    "routes": [
      {
        "path": "/packs/chaos-probe",
        "component": "ops/ChaosProbePackPage",
        "title": "Chaos Probe"
      }
    ],
    "assets": {
      "type": "builtin",
      "entry": "ops/ChaosProbePackPage"
    }
  },
  "sdk": {
    "typescript": "yunque-client/chaos-probe"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "blueprint": "doc/CHAOS-PROBE.md",
    "stage": "pack-shell-before-scheduler",
    "risk": "ops-governance",
    "sync": "backend-registry-drives-frontend",
    "descriptionStyle": "one-line-plus-three-examples",
    "example1": "维护探针清单并执行一次安全演练。",
    "example2": "生成调度、指标与降级写回计划。",
    "example3": "导出本次探针运行的证据包。",
    "usability": "experimental",
    "limitation": "当前主要用于安全演练和治理计划，调度、指标写回、告警写回仍是计划/本地记录，不会直接改动生产降级状态。"
  },
  "status": "alpha"
}
