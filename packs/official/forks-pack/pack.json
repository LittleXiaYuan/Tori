{
  "id": "yunque.pack.forks",
  "name": "Conversation Forks (对话分支)",
  "version": "0.1.0",
  "description": "对话分支能力：创建、查看、删除会话分叉，并从任意消息位置创建新分支。默认预装，由聊天与会话历史相关界面调用。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "enabled",
  "backend": {
    "capabilities": [
      "forks.read",
      "forks.create",
      "forks.delete",
      "forks.branch",
      "forks.list"
    ],
    "routes": [
      "/v1/fork",
      "/v1/fork/branch",
      "/v1/fork/list"
    ],
    "permissions": [
      "forks:read",
      "forks:write"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/fork",
        "description": "Read a conversation fork or the root fork for a session."
      },
      {
        "method": "POST",
        "path": "/v1/fork",
        "description": "Create a root conversation fork."
      },
      {
        "method": "DELETE",
        "path": "/v1/fork",
        "description": "Delete a conversation fork."
      },
      {
        "method": "POST",
        "path": "/v1/fork/branch",
        "description": "Create a branch from an existing conversation fork."
      },
      {
        "method": "GET",
        "path": "/v1/fork/list",
        "description": "List conversation forks for a session."
      }
    ]
  },
  "frontend": {
    "menus": [],
    "assets": {
      "type": "builtin"
    }
  },
  "sdk": {
    "typescript": "yunque-client/forks"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "group": "chat",
    "phase": "A3",
    "preload": "true",
    "note": "Default-preloaded chat-history pack: natively owns /v1/fork* through Pack Runtime. Existing chat/session surfaces consume this API.",
    "usability": "infrastructure",
    "primaryActionLabel": "开始分支对话",
    "primaryActionPath": "/chat?q=%E6%88%91%E6%83%B3%E4%BB%8E%E5%BD%93%E5%89%8D%E6%80%9D%E8%B7%AF%E5%88%86%E5%87%BA%E4%B8%80%E6%9D%A1%E6%96%B0%E5%AF%B9%E8%AF%9D%EF%BC%8C%E5%B8%AE%E6%88%91%E4%BF%9D%E7%95%99%E4%B8%BB%E7%BA%BF%E5%B9%B6%E5%BC%80%E5%A7%8B%E4%B8%80%E4%B8%AA%E5%8F%AF%E5%9B%9E%E6%BA%AF%E7%9A%84%E5%88%86%E6%94%AF",
    "usageSurface": "Chat 会话历史、消息分支入口、分支对话与上下文切换",
    "example1": "从某条消息位置创建新的对话分支。",
    "example2": "查看一个会话下已有的分支并切换上下文。",
    "example3": "删除不再需要的分支，保留主线对话清晰。"
  },
  "status": "beta"
}
