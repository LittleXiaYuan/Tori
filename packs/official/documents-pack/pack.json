{
  "id": "yunque.pack.documents",
  "name": "Documents (文档生成)",
  "version": "0.1.0",
  "description": "文档生成能力：通过技能生成 docx/xlsx/html/pptx，并读取文档模板目录。默认预装，由任务产物和文档生成入口调用。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "enabled",
  "backend": {
    "capabilities": [
      "documents.generate",
      "documents.templates.read"
    ],
    "routes": [
      "/v1/documents/generate",
      "/v1/documents/templates"
    ],
    "permissions": [
      "documents:read",
      "documents:write",
      "skills:execute",
      "filesystem:write"
    ],
    "routeSpecs": [
      {
        "method": "POST",
        "path": "/v1/documents/generate",
        "description": "Generate a document through the registered document skills."
      },
      {
        "method": "GET",
        "path": "/v1/documents/templates",
        "description": "Read the document template catalog."
      }
    ]
  },
  "frontend": {
    "menus": [],
    "assets": {
      "type": "builtin"
    }
  },
  "sdk": {
    "typescript": "yunque-client/documents"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "group": "work",
    "phase": "A4",
    "preload": "true",
    "note": "Natively owns /v1/documents/* through Pack Runtime. It reaches document skills through a narrow SkillsRegistry accessor.",
    "usability": "infrastructure",
    "primaryActionLabel": "开始生成文档",
    "primaryActionPath": "/chat?q=%E5%B8%AE%E6%88%91%E7%94%9F%E6%88%90%E4%B8%80%E4%BB%BD%E5%8F%AF%E4%B8%8B%E8%BD%BD%E7%9A%84%E6%96%87%E6%A1%A3%EF%BC%8C%E5%85%88%E9%97%AE%E6%88%91%E4%B8%BB%E9%A2%98%E3%80%81%E6%A0%BC%E5%BC%8F%E5%92%8C%E6%A8%A1%E6%9D%BF%E8%A6%81%E6%B1%82",
    "usageSurface": "Chat 自动发起文档任务、任务产物区、文档生成技能与模板目录",
    "example1": "在对话里要求云雀生成 docx、xlsx、html 或 pptx。",
    "example2": "任务完成后在产物区预览或下载生成文件。",
    "example3": "读取模板目录，让文档输出沿用固定格式。"
  },
  "status": "beta"
}
