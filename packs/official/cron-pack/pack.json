{
  "id": "yunque.pack.cron",
  "name": "Cron (定时任务)",
  "version": "0.1.0",
  "description": "定时任务能力：查看、创建、删除并立即运行定时任务。默认预装，由任务和自动化界面调用。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "enabled",
  "backend": {
    "capabilities": [
      "cron.jobs.read",
      "cron.jobs.write",
      "cron.jobs.run"
    ],
    "routes": [
      "/v1/cron/list",
      "/v1/cron/add",
      "/v1/cron/remove",
      "/v1/cron/run"
    ],
    "permissions": [
      "cron:read",
      "cron:write",
      "tasks:run"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/cron/list",
        "description": "List registered cron jobs."
      },
      {
        "method": "POST",
        "path": "/v1/cron/add",
        "description": "Create a cron job."
      },
      {
        "method": "DELETE",
        "path": "/v1/cron/remove",
        "description": "Remove a cron job by id."
      },
      {
        "method": "POST",
        "path": "/v1/cron/run",
        "description": "Run a cron job immediately."
      }
    ]
  },
  "frontend": {
    "menus": [],
    "assets": {
      "type": "builtin"
    }
  },
  "sdk": {
    "typescript": "yunque-client/cron"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "group": "automation",
    "phase": "A4",
    "preload": "true",
    "note": "Natively owns /v1/cron/* through Pack Runtime. Existing task and automation surfaces consume this API."
  },
  "status": "beta"
}
