{
  "id": "yunque.pack.sbom-drift",
  "name": "SBOM Drift Pack",
  "version": "0.1.0",
  "description": "将 SBOM 快照、Go/npm 依赖漂移检测和供应链证据包导出作为可选运维能力包暴露。",
  "requiresCore": ">=0.1.0",
  "optional": true,
  "defaultState": "disabled",
  "backend": {
    "capabilities": [
      "sbom.status",
      "sbom.snapshot.create",
      "sbom.snapshot.list",
      "sbom.snapshot.detail",
      "sbom.drift.diff",
      "sbom.evidence.export"
    ],
    "routes": [
      "/v1/sbom-drift/status",
      "/v1/sbom-drift/snapshots",
      "/v1/sbom-drift/snapshots/",
      "/v1/sbom-drift/diff",
      "/v1/sbom-drift/evidence/"
    ],
    "permissions": [
      "sbom:read",
      "sbom:write",
      "sbom:audit"
    ],
    "routeSpecs": [
      {
        "method": "GET",
        "path": "/v1/sbom-drift/status",
        "description": "Read SBOM drift pack shell status and scanner readiness."
      },
      {
        "method": "GET",
        "path": "/v1/sbom-drift/snapshots",
        "description": "List stored dependency snapshots."
      },
      {
        "method": "POST",
        "path": "/v1/sbom-drift/snapshots",
        "description": "Create a Go/npm dependency snapshot from the current working tree."
      },
      {
        "method": "GET",
        "path": "/v1/sbom-drift/snapshots/",
        "description": "Read one stored dependency snapshot by id."
      },
      {
        "method": "POST",
        "path": "/v1/sbom-drift/diff",
        "description": "Compare a stored baseline with another snapshot or the current working tree."
      },
      {
        "method": "GET",
        "path": "/v1/sbom-drift/evidence/",
        "description": "Export a JSON evidence pack for one dependency snapshot."
      }
    ]
  },
  "frontend": {
    "menus": [
      {
        "key": "sbom-drift",
        "label": "SBOM 漂移",
        "path": "/packs/sbom-drift",
        "icon": "shield-check",
        "order": 96
      }
    ],
    "routes": [
      {
        "path": "/packs/sbom-drift",
        "component": "sbom/SBOMDriftPackPage",
        "title": "SBOM 漂移"
      }
    ],
    "assets": {
      "type": "builtin",
      "entry": "sbom/SBOMDriftPackPage"
    }
  },
  "sdk": {
    "typescript": "yunque-client/sbom-drift"
  },
  "update": {
    "channel": "stable",
    "rollback": true
  },
  "metadata": {
    "blueprint": "doc/SBOM-DRIFT-DETECTION.md",
    "stage": "pack-shell-before-ci",
    "sync": "backend-registry-drives-frontend"
  },
  "distribution": {
    "manifestUrl": "https://packs.yunque.local/sbom-drift-pack/pack.json",
    "packageUrl": "https://packs.yunque.local/sbom-drift-pack/sbom-drift-pack-0.1.0.tgz",
    "frontendUrl": "https://packs.yunque.local/sbom-drift-pack/frontend/remoteEntry.js",
    "sha256": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
    "sizeBytes": 4096
  }
}
