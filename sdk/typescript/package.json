{
  "name": "yunque-client",
  "version": "0.1.0",
  "description": "TypeScript client for the Yunque (云雀) Agent HTTP API. Auto-generated from docs/openapi.yaml.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./planner-recovery": {
      "types": "./src/planner-recovery.ts",
      "import": "./src/planner-recovery.ts"
    },
    "./chat": {
      "types": "./src/chat.ts",
      "import": "./src/chat.ts"
    },
    "./memory": {
      "types": "./src/memory.ts",
      "import": "./src/memory.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "npm run typecheck:test && node scripts/run-incremental-tests.mjs"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.81.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.10.0"
  }
}
