{
  "version": 1,
  "domain": "cognis",
  "description": "Cross-language lightweight SDK entrypoints for Cogni registry, observability, experience recording, evolution, bundle import/export, workflows, and federation helpers.",
  "principles": [
    "Expose CogniKernel and multi-cogni capabilities as focused SDK slices instead of hiding them inside platform pages.",
    "Keep Cogni registry, traces, experience, evolution, and federation directly callable from frontends, plugins, CLIs, sidecars, and automation scripts.",
    "Make Cognis access available through Agent Kit without coupling callers to backend internals."
  ],
  "routes": [
    "GET /v1/cognis",
    "POST /v1/cognis",
    "GET /v1/cognis/{id}",
    "DELETE /v1/cognis/{id}",
    "POST /v1/cognis/{id}/enable",
    "POST /v1/cognis/{id}/disable",
    "POST /v1/cognis/reload",
    "GET /v1/cognis/traces",
    "GET /v1/cognis/{id}/trace",
    "GET /v1/cognis/stats",
    "GET /v1/cognis/health",
    "GET /v1/cognis/{id}/health",
    "GET /v1/cognis/verify",
    "GET /v1/cognis/{id}/verify",
    "GET /v1/cognis/alerts",
    "POST /v1/cognis/alerts/scan",
    "POST /v1/cognis/generate",
    "GET /v1/cognis/export",
    "POST /v1/cognis/import",
    "GET /v1/cognis/{id}/workflows",
    "POST /v1/cognis/{id}/workflow/{name}",
    "GET /v1/cognis/{id}/experience",
    "POST /v1/cognis/{id}/experience/record",
    "POST /v1/cognis/{id}/experience/patterns/{patternId}/confirm",
    "POST /v1/cognis/{id}/evolve",
    "GET /v1/cognis/evolution",
    "GET /v1/cognis/{id}/evolution",
    "GET /v1/cognis/federation",
    "GET /v1/cognis/federation/peers",
    "POST /v1/cognis/federation/discover",
    "POST /v1/cognis/{id}/expose",
    "POST /v1/cognis/{id}/unexpose",
    "GET /v1/cognis/economics"
  ],
