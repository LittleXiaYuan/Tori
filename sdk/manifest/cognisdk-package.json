{
  "version": 1,
  "domain": "cognisdk-package",
  "description": "Local experimental Cognition SDK package and CLI surfaces for declarative Cogni Pack bundles, feedback proposals, schemas, review gates, and rollback-friendly automation.",
  "principles": [
    "Expose cognition state and pack bundle capabilities as a small Go SDK instead of platform-only internals.",
    "Keep bundle review, digest checks, golden tests, schema export, and promote flows non-mutating until a caller explicitly writes files.",
    "Make package and CLI entrypoints directly usable by external projects, frontends, plugins, CI, and automation scripts."
  ],
  "goPackage": {
    "importPath": "yunque-agent/pkg/cognisdk",
    "implementationFiles": [
      "pkg/cognisdk/doc.go",
      "pkg/cognisdk/types.go",
      "pkg/cognisdk/engine.go",
      "pkg/cognisdk/host.go",
      "pkg/cognisdk/feedback.go",
      "pkg/cognisdk/feedback_render.go",
      "pkg/cognisdk/pack.go",
      "pkg/cognisdk/pack_io.go",
      "pkg/cognisdk/pack_bundle.go",
      "pkg/cognisdk/pack_digest.go",
      "pkg/cognisdk/pack_summary.go",
      "pkg/cognisdk/pack_diff.go",
      "pkg/cognisdk/pack_review.go",
      "pkg/cognisdk/pack_plan.go",
      "pkg/cognisdk/golden.go",
      "pkg/cognisdk/schema.go"
    ]
  },
  "capabilities": [
    {
      "name": "evaluate",
      "symbols": [
        "NewEngine",
        "Evaluate",
        "RenderMarkdown"
      ]
    },
    {
      "name": "hostAdapter",
      "symbols": [
        "NewHostAdapter",
        "NewHostAdapterFromDir",
        "NewHostAdapterFromBundle",
        "BuildContext"
      ]
    },
    {
      "name": "feedbackProposal",
      "symbols": [
        "AuditFeedback",
        "BuildFeedbackProposal",
        "ProposeUpdates",
        "RenderFeedbackProposalMarkdown"
      ]
    },
    {
      "name": "packManager",
      "symbols": [
        "NewPackManager",
        "List",
        "Enable",
        "Disable",
        "Merge",
        "ValidatePack"
      ]
    },
    {
      "name": "packIO",
      "symbols": [
        "LoadPackManifest",
        "LoadPacksFromDir",
        "SavePackManifest",
        "NewPackManagerFromDir"
      ]
    },
    {
      "name": "packBundle",
      "symbols": [
        "PackBundle",
        "NewPackBundle",
        "ExportBundle",
        "LoadPackBundle",
        "SavePackBundle",
        "NewPackManagerFromBundle"
      ]
    },
    {
      "name": "packBundleDigest",
      "symbols": [
        "CanonicalPackBundle",
        "DigestPackBundle",
        "PackBundleDigestCheck",
        "VerifyPackBundleDigest"
      ]
    },
    {
      "name": "packBundleSummary",
      "symbols": [
        "PackBundleSummary",
        "SummarizePackBundle",
        "RenderPackBundleSummaryMarkdown"
      ]
    },
    {
      "name": "packBundleDiff",
      "symbols": [
        "PackBundleDiff",
        "DiffPackBundles",
        "RenderPackBundleDiffMarkdown"
      ]
    },
    {
      "name": "packBundleReview",
      "symbols": [
        "PackBundleReview",
        "ReviewPackBundleCandidate",
        "RenderPackBundleReviewMarkdown"
      ]
    },
    {
      "name": "packBundleApplyPlan",
      "symbols": [
        "PackBundleApplyPlan",
        "PackBundleApplyActionKind",
        "PackBundleApplyActionKindInfo",
        "PackBundleApplyChecklistItem",
        "PackBundleApplyAction",
        "PlanPackBundleApply",
        "RenderPackBundleApplyPlanMarkdown",
        "PackBundleApplyActionKinds",
        "PackBundleApplyActionKindInfos",
        "DescribePackBundleApplyActionKind",
        "BuildPackBundleApplyChecklist",
        "FilterPackBundleApplyActions",
        "KnownPackBundleApplyActionKind",
        "Actions",
        "RecommendedActions"
      ]
    },
    {
      "name": "goldenGate",
      "symbols": [
        "RunGoldenTests",
        "RunPackBundleGoldenTests",
        "RenderGoldenTestSummaryMarkdown"
      ]
    },
    {
      "name": "jsonSchemas",
      "symbols": [
        "PackManifestJSONSchema",
        "PackBundleJSONSchema",
        "PackBundleSummaryJSONSchema",
        "PackBundleDigestCheckJSONSchema",
        "PackBundleDiffJSONSchema",
        "PackBundleReviewJSONSchema",
        "PackBundleApplyPlanJSONSchema",
        "PackBundleApplyActionsJSONSchema",
        "PackBundleApplyActionKindsJSONSchema",
        "PackBundleApplyChecklistJSONSchema",
        "FeedbackProposalJSONSchema",
        "JSONSchemaInfo",
        "JSONSchemaInfos",
        "JSONSchemaByName"
      ]
    }
  ],
  "cli": [
    {
      "name": "cognisdk-schema",
      "file": "cmd/cognisdk-schema/main.go",
      "commands": [
        "list"
      ],
      "flags": [
        "--json",
        "--out"
      ],
      "schemas": [
        "pack-manifest",
        "pack-bundle",
        "pack-bundle-summary",
        "pack-bundle-digest-check",
        "pack-bundle-diff",
        "pack-bundle-review",
        "pack-bundle-apply-plan",
        "pack-bundle-apply-actions",
        "pack-bundle-apply-action-kinds",
        "pack-bundle-apply-checklist",
        "feedback-proposal"
      ]
    },
    {
      "name": "cognisdk-bundle",
      "file": "cmd/cognisdk-bundle/main.go",
      "commands": [
        "init",
        "action-kinds",
        "actions",
        "checklist",
        "digest",
        "inspect",
        "diff",
        "golden",
        "review",
        "plan",
        "promote"
      ],
      "flags": [
        "--builtin",
        "--markdown",
        "--allow-review",
        "--review-out",
        "--out",
        "--kind",
        "--fail-on-review",
        "--fail-on-blocked",
        "--expect",
        "--details"
      ]
    }
  ],
  "tests": [
    "pkg/cognisdk/example_external_test.go",
    "pkg/cognisdk/feedback_test.go",
    "pkg/cognisdk/pack_bundle_test.go",
    "pkg/cognisdk/pack_diff_test.go",
    "pkg/cognisdk/pack_review_test.go",
    "pkg/cognisdk/pack_plan_test.go",
    "pkg/cognisdk/schema_test.go",
    "cmd/cognisdk-schema/main_test.go",
    "cmd/cognisdk-bundle/main_test.go"
  ],
  "docs": [
    "docs/guide/cognisdk-feedback.md",
    "docs/zh/guide/cognisdk-feedback.md"
  ]
}
