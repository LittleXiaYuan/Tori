{
  "version": 1,
  "domain": "plugin-toggle",
  "description": "Cross-language lightweight SDK for enabling and disabling plugins without importing the full platform client or broader Plugins management slice.",
  "principles": [
    "Expose plugin enable/disable control as a focused operator SDK slice for plugin marketplaces, admin pages, CLIs, sidecars, and automation scripts.",
    "Keep plugin toggles directly callable through the existing authenticated gateway route.",
    "Make PluginToggle available through Agent Kit while preserving a standalone composable facade."
  ],
  "routes": [
    "POST /v1/plugins/toggle"
  ],
  "capabilities": [
    {
      "name": "toggle",
      "route": "POST /v1/plugins/toggle",
      "readOnly": false,
      "description": "Enable or disable a plugin by name."
    }
  ],
  "languages": {
    "typescript": {
      "package": "yunque-client",
      "implementationFiles": [
        "packages/yunque-client/src/plugin-toggle.ts",
        "packages/yunque-client/src/agent-kit.ts"
      ],
      "docs": [
        "packages/yunque-client/README.md",
        "docs/plugins/sdk-typescript.md"
      ],
      "entrypoints": {
        "toggle": "createPluginToggleClient().toggle"
      }
    },
    "go": {
      "package": "yunque-agent/sdk/go/yunque",
      "implementationFiles": [
        "sdk/go/yunque/yunque.go"
      ],
      "docs": [
        "sdk/go/README.md",
        "docs/plugins/sdk-go.md"
      ],
      "entrypoints": {
        "toggle": "yunque.PluginToggle.Toggle"
      }
    },
    "python": {
      "package": "yunque",
      "implementationFiles": [
        "sdk/python/yunque/__init__.py"
      ],
      "docs": [
        "sdk/python/README.md",
        "docs/plugins/sdk-python.md"
      ],
      "entrypoints": {
        "toggle": "yunque.plugin_toggle.toggle"
      }
    },
    "rust": {
      "package": "yunque-client",
      "implementationFiles": [
        "sdk/rust/src/lib.rs"
      ],
      "docs": [
        "sdk/rust/README.md",
        "docs/plugins/sdk-rust.md"
      ],
      "entrypoints": {
        "toggle": "PluginToggleClient::toggle"
      }
    }
  },
  "overviewDocs": [
    "docs/plugins/sdk-overview.md",
    "docs/plugins/overview.md",
    "docs/plugins/developing.md"
  ]
}
