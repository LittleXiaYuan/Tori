{
  "version": 1,
  "domain": "identity",
  "description": "Cross-language lightweight SDK entrypoints for cross-channel identity resolution and identity profile listing without importing the full platform client.",
  "principles": [
    "Expose identity resolution as focused SDK helpers for external channel adapters, plugin UIs, CLIs, sidecars, and automation scripts.",
    "Keep resolve/profile workflows directly callable through the existing authenticated /v1/identity routes.",
    "Make Identity access available through Agent Kit while preserving Discovery as the broader identity, embeddings, and search slice."
  ],
  "routes": [
    "POST /v1/identity/resolve",
    "GET /v1/identity/profiles"
  ],
  "capabilities": [
    {
      "name": "resolve",
      "route": "POST /v1/identity/resolve",
      "readOnly": false,
      "description": "Resolve a channel-specific user into a unified identity profile."
    },
    {
      "name": "profiles",
      "route": "GET /v1/identity/profiles",
      "readOnly": true,
      "description": "List known identity profiles."
    }
  ],
  "languages": {
    "typescript": {
      "package": "yunque-client",
      "implementationFiles": [
        "packages/yunque-client/src/identity.ts",
        "packages/yunque-client/src/agent-kit.ts"
      ],
      "docs": [
        "packages/yunque-client/README.md",
        "docs/plugins/sdk-typescript.md"
      ],
      "entrypoints": {
        "resolve": "createIdentityClient().resolve",
        "profiles": "createIdentityClient().profiles"
      }
    },
    "go": {
      "package": "yunque-agent/sdk/go/yunque",
      "implementationFiles": [
        "sdk/go/yunque/yunque.go"
      ],
      "docs": [
        "sdk/go/README.md",
        "docs/plugins/sdk-go.md"
      ],
      "entrypoints": {
        "resolve": "yunque.Identity.Resolve",
        "profiles": "yunque.Identity.Profiles"
      }
    },
    "python": {
      "package": "yunque",
      "implementationFiles": [
        "sdk/python/yunque/__init__.py"
      ],
      "docs": [
        "sdk/python/README.md",
        "docs/plugins/sdk-python.md"
      ],
      "entrypoints": {
        "resolve": "yunque.identity.resolve",
        "profiles": "yunque.identity.profiles"
      }
    },
    "rust": {
      "package": "yunque-client",
      "implementationFiles": [
        "sdk/rust/src/lib.rs"
      ],
      "docs": [
        "sdk/rust/README.md",
        "docs/plugins/sdk-rust.md"
      ],
      "entrypoints": {
        "resolve": "IdentityClient::resolve",
        "profiles": "IdentityClient::profiles"
      }
    }
  },
  "overviewDocs": [
    "docs/plugins/sdk-overview.md",
    "docs/plugins/overview.md",
    "docs/plugins/developing.md"
  ]
}
