{
  "version": 1,
  "domain": "plugin-api-runtime",
  "description": "Lightweight SDK entrypoints for plugin and automation scripts to consume Yunque runtime capabilities through /v1/plugin-api/*.",
  "principles": [
    "Expose plugin runtime capabilities as small SDK slices callable from plugins, frontends, sidecars, CLIs, and automation scripts.",
    "Keep read-only plugin slices separate from write or system-extension slices where possible.",
    "Guard the plugin API surface against drift between gateway routes, TypeScript focused slices, Go/Python runtime helpers, and documentation."
  ],
  "routes": [
    "POST /v1/plugin-api/llm",
    "POST /v1/plugin-api/search",
    "POST /v1/plugin-api/send",
    "POST /v1/plugin-api/memory/get",
    "POST /v1/plugin-api/memory/set",
    "POST /v1/plugin-api/memory/delete",
    "POST /v1/plugin-api/memory/list",
    "POST /v1/plugin-api/memory/search",
    "POST /v1/plugin-api/agent-memory/search",
    "POST /v1/plugin-api/agent-memory/add",
    "POST /v1/plugin-api/knowledge/search",
    "POST /v1/plugin-api/knowledge/ingest",
    "POST /v1/plugin-api/cron/add",
    "POST /v1/plugin-api/cron/remove",
    "GET /v1/plugin-api/cron/list",
    "POST /v1/plugin-api/register/provider",
    "POST /v1/plugin-api/register/channel",
    "POST /v1/plugin-api/register/search",
    "POST /v1/plugin-api/register/guardrail",
    "POST /v1/plugin-api/register/embedding",
    "POST /v1/plugin-api/register/speech",
    "GET /v1/plugin-api/extensions"
  ],
  "capabilities": [
    { "name": "llm", "route": "POST /v1/plugin-api/llm", "readOnly": false, "description": "Call the configured LLM through the plugin API." },
    { "name": "search", "route": "POST /v1/plugin-api/search", "readOnly": true, "description": "Search through configured search providers." },
    { "name": "send", "route": "POST /v1/plugin-api/send", "readOnly": false, "description": "Send a message through an enabled channel." },
    { "name": "memoryGet", "route": "POST /v1/plugin-api/memory/get", "readOnly": true, "description": "Read plugin-private memory." },
    { "name": "memorySet", "route": "POST /v1/plugin-api/memory/set", "readOnly": false, "description": "Write plugin-private memory." },
    { "name": "memoryDelete", "route": "POST /v1/plugin-api/memory/delete", "readOnly": false, "description": "Delete plugin-private memory." },
    { "name": "memoryList", "route": "POST /v1/plugin-api/memory/list", "readOnly": true, "description": "List plugin-private memory entries." },
    { "name": "memorySearch", "route": "POST /v1/plugin-api/memory/search", "readOnly": true, "description": "Search plugin-private memory." },
    { "name": "agentMemorySearch", "route": "POST /v1/plugin-api/agent-memory/search", "readOnly": true, "description": "Search shared agent memory." },
    { "name": "agentMemoryAdd", "route": "POST /v1/plugin-api/agent-memory/add", "readOnly": false, "description": "Write shared agent memory." },
    { "name": "knowledgeSearch", "route": "POST /v1/plugin-api/knowledge/search", "readOnly": true, "description": "Search the agent knowledge base." },
    { "name": "knowledgeIngest", "route": "POST /v1/plugin-api/knowledge/ingest", "readOnly": false, "description": "Ingest content into the knowledge base." },
    { "name": "cronAdd", "route": "POST /v1/plugin-api/cron/add", "readOnly": false, "description": "Create a plugin-owned scheduled task." },
    { "name": "cronRemove", "route": "POST /v1/plugin-api/cron/remove", "readOnly": false, "description": "Remove a plugin-owned scheduled task." },
    { "name": "cronList", "route": "GET /v1/plugin-api/cron/list", "readOnly": true, "description": "List plugin-owned scheduled tasks." },
    { "name": "registerProvider", "route": "POST /v1/plugin-api/register/provider", "readOnly": false, "description": "Register a plugin-provided LLM provider." },
    { "name": "registerChannel", "route": "POST /v1/plugin-api/register/channel", "readOnly": false, "description": "Register a plugin-provided channel adapter." },
    { "name": "registerSearch", "route": "POST /v1/plugin-api/register/search", "readOnly": false, "description": "Register a plugin-provided search engine." },
    { "name": "registerGuardrail", "route": "POST /v1/plugin-api/register/guardrail", "readOnly": false, "description": "Register a plugin-provided guardrail." },
    { "name": "registerEmbedding", "route": "POST /v1/plugin-api/register/embedding", "readOnly": false, "description": "Register a plugin-provided embedding provider." },
    { "name": "registerSpeech", "route": "POST /v1/plugin-api/register/speech", "readOnly": false, "description": "Register a plugin-provided speech provider." },
    { "name": "extensions", "route": "GET /v1/plugin-api/extensions", "readOnly": true, "description": "List plugin-contributed system extensions." }
  ],
  "languages": {
    "typescript": {
      "package": "yunque-client",
      "implementationFiles": [
        "packages/yunque-client/src/plugin-api.ts",
        "packages/yunque-client/src/plugin-llm.ts",
        "packages/yunque-client/src/plugin-search.ts",
        "packages/yunque-client/src/plugin-send.ts",
        "packages/yunque-client/src/plugin-memory.ts",
        "packages/yunque-client/src/plugin-agent-memory.ts",
        "packages/yunque-client/src/plugin-knowledge.ts",
        "packages/yunque-client/src/plugin-cron.ts",
        "packages/yunque-client/src/plugin-extensions.ts",
        "packages/yunque-client/src/plugin-extension-register.ts"
      ],
      "docs": ["packages/yunque-client/README.md", "docs/plugins/sdk-typescript.md"],
      "entrypoints": {
        "llm": "yunque-client/plugin-llm#createPluginLLMClient().complete",
        "search": "yunque-client/plugin-search#createPluginSearchClient().search",
        "send": "yunque-client/plugin-send#createPluginSendClient().send",
        "memoryGet": "yunque-client/plugin-memory#createPluginMemoryClient().get",
        "memorySet": "yunque-client/plugin-memory#createPluginMemoryClient().set",
        "memoryDelete": "yunque-client/plugin-memory#createPluginMemoryClient().delete",
        "memoryList": "yunque-client/plugin-memory#createPluginMemoryClient().list",
        "memorySearch": "yunque-client/plugin-memory#createPluginMemoryClient().search",
        "agentMemorySearch": "yunque-client/plugin-agent-memory#createPluginAgentMemoryClient().search",
        "agentMemoryAdd": "yunque-client/plugin-agent-memory#createPluginAgentMemoryClient().add",
        "knowledgeSearch": "yunque-client/plugin-knowledge#createPluginKnowledgeClient().search",
        "knowledgeIngest": "yunque-client/plugin-knowledge#createPluginKnowledgeClient().ingest",
        "cronAdd": "yunque-client/plugin-cron#createPluginCronClient().add",
        "cronRemove": "yunque-client/plugin-cron#createPluginCronClient().remove",
        "cronList": "yunque-client/plugin-cron#createPluginCronClient().list",
        "registerProvider": "yunque-client/plugin-extensions#createPluginExtensionsClient().registerProvider",
        "registerChannel": "yunque-client/plugin-extensions#createPluginExtensionsClient().registerChannel",
        "registerSearch": "yunque-client/plugin-extensions#createPluginExtensionsClient().registerSearch",
        "registerGuardrail": "yunque-client/plugin-extensions#createPluginExtensionsClient().registerGuardrail",
        "registerEmbedding": "yunque-client/plugin-extensions#createPluginExtensionsClient().registerEmbedding",
        "registerSpeech": "yunque-client/plugin-extensions#createPluginExtensionsClient().registerSpeech",
        "extensions": "yunque-client/plugin-extensions#createPluginExtensionsClient().list"
      }
    },
    "go": {
      "package": "yunque-agent/sdk/go/yunque",
      "implementationFiles": ["sdk/go/yunque/yunque.go"],
      "docs": ["sdk/go/README.md", "docs/plugins/sdk-go.md"],
      "entrypoints": {
        "llm": "yunque.LLM",
        "search": "yunque.Search",
        "send": "yunque.Send",
        "memoryGet": "yunque.Memory.Get",
        "memorySet": "yunque.Memory.Set",
        "memoryDelete": "yunque.Memory.Delete",
        "memoryList": "yunque.Memory.List",
        "memorySearch": "yunque.Memory.Search",
        "agentMemorySearch": "yunque.AgentMemory.Search",
        "agentMemoryAdd": "yunque.AgentMemory.Add",
        "knowledgeSearch": "yunque.Knowledge.Search",
        "knowledgeIngest": "yunque.Knowledge.Ingest",
        "cronAdd": "yunque.Cron.Add",
        "cronRemove": "yunque.Cron.Remove",
        "cronList": "yunque.Cron.List"
      }
    },
    "python": {
      "package": "yunque",
      "implementationFiles": ["sdk/python/yunque/__init__.py"],
      "docs": ["sdk/python/README.md", "docs/plugins/sdk-python.md"],
      "entrypoints": {
        "llm": "yunque.llm",
        "search": "yunque.search",
        "send": "yunque.send",
        "memoryGet": "yunque.memory.get",
        "memorySet": "yunque.memory.set",
        "memoryDelete": "yunque.memory.delete",
        "memoryList": "yunque.memory.list",
        "memorySearch": "yunque.memory.search",
        "agentMemorySearch": "yunque.agent_memory.search",
        "agentMemoryAdd": "yunque.agent_memory.add",
        "knowledgeSearch": "yunque.knowledge.search",
        "knowledgeIngest": "yunque.knowledge.ingest",
        "cronAdd": "yunque.cron.add",
        "cronRemove": "yunque.cron.remove",
        "cronList": "yunque.cron.list",
        "registerProvider": "yunque.register_provider",
        "registerChannel": "yunque.register_channel",
        "registerSearch": "yunque.register_search",
        "registerGuardrail": "yunque.register_guardrail",
        "registerEmbedding": "yunque.register_embedding",
        "registerSpeech": "yunque.register_speech",
        "extensions": "yunque.list_extensions"
      }
    },
    "rust": {
      "package": "yunque-client",
      "implementationFiles": ["sdk/rust/src/lib.rs"],
      "docs": ["sdk/rust/README.md", "docs/plugins/sdk-rust.md"],
      "entrypoints": {
        "llm": "PluginApiClient::llm",
        "search": "PluginApiClient::search",
        "send": "PluginApiClient::send",
        "memoryGet": "PluginApiClient::memory_get",
        "memorySet": "PluginApiClient::memory_set",
        "memoryDelete": "PluginApiClient::memory_delete",
        "memoryList": "PluginApiClient::memory_list",
        "memorySearch": "PluginApiClient::memory_search",
        "agentMemorySearch": "PluginApiClient::agent_memory_search",
        "agentMemoryAdd": "PluginApiClient::agent_memory_add",
        "knowledgeSearch": "PluginApiClient::knowledge_search",
        "knowledgeIngest": "PluginApiClient::knowledge_ingest",
        "cronAdd": "PluginApiClient::cron_add",
        "cronRemove": "PluginApiClient::cron_remove",
        "cronList": "PluginApiClient::cron_list",
        "registerProvider": "PluginApiClient::register_provider",
        "registerChannel": "PluginApiClient::register_channel",
        "registerSearch": "PluginApiClient::register_search",
        "registerGuardrail": "PluginApiClient::register_guardrail",
        "registerEmbedding": "PluginApiClient::register_embedding",
        "registerSpeech": "PluginApiClient::register_speech",
        "extensions": "PluginApiClient::extensions"
      }
    }
  },
  "overviewDocs": ["docs/plugins/sdk-overview.md", "docs/plugins/overview.md", "docs/plugins/developing.md"]
}
