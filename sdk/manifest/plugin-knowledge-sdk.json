{
  "version": 1,
  "domain": "plugin-knowledge",
  "description": "Cross-language lightweight SDK for plugin-scoped knowledge/RAG search and ingest without importing the full platform client or broader Plugin API runtime slice.",
  "principles": [
    "Expose plugin-scoped knowledge search and ingest as a focused SDK slice for plugins, external frontends, CLIs, sidecars, and automation scripts.",
    "Keep RAG access directly callable through existing plugin-authenticated runtime routes.",
    "Make PluginKnowledge available through Agent Kit while preserving a standalone composable facade."
  ],
  "routes": [
    "POST /v1/plugin-api/knowledge/search",
    "POST /v1/plugin-api/knowledge/ingest"
  ],
  "capabilities": [
    {
      "name": "search",
      "route": "POST /v1/plugin-api/knowledge/search",
      "readOnly": true,
      "description": "Search the knowledge base through a plugin-scoped token."
    },
    {
      "name": "ingest",
      "route": "POST /v1/plugin-api/knowledge/ingest",
      "readOnly": false,
      "description": "Ingest content into the knowledge base through a plugin-scoped token."
    }
  ],
  "languages": {
    "typescript": {
      "package": "yunque-client",
      "implementationFiles": [
        "packages/yunque-client/src/plugin-knowledge.ts",
        "packages/yunque-client/src/agent-kit.ts"
      ],
      "docs": [
        "packages/yunque-client/README.md",
        "docs/plugins/sdk-typescript.md"
      ],
      "entrypoints": {
        "search": "createPluginKnowledgeClient().search",
        "ingest": "createPluginKnowledgeClient().ingest"
      }
    },
    "go": {
      "package": "yunque-agent/sdk/go/yunque",
      "implementationFiles": [
        "sdk/go/yunque/yunque.go"
      ],
      "docs": [
        "sdk/go/README.md",
        "docs/plugins/sdk-go.md"
      ],
      "entrypoints": {
        "search": "yunque.PluginKnowledge.Search",
        "ingest": "yunque.PluginKnowledge.Ingest"
      }
    },
    "python": {
      "package": "yunque",
      "implementationFiles": [
        "sdk/python/yunque/__init__.py"
      ],
      "docs": [
        "sdk/python/README.md",
        "docs/plugins/sdk-python.md"
      ],
      "entrypoints": {
        "search": "yunque.plugin_knowledge.search",
        "ingest": "yunque.plugin_knowledge.ingest"
      }
    },
    "rust": {
      "package": "yunque-client",
      "implementationFiles": [
        "sdk/rust/src/lib.rs"
      ],
      "docs": [
        "sdk/rust/README.md",
        "docs/plugins/sdk-rust.md"
      ],
      "entrypoints": {
        "search": "PluginKnowledgeClient::search",
        "ingest": "PluginKnowledgeClient::ingest"
      }
    }
  },
  "overviewDocs": [
    "docs/plugins/sdk-overview.md",
    "docs/plugins/overview.md",
    "docs/plugins/developing.md"
  ]
}
