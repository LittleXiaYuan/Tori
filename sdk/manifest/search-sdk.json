{
  "version": 1,
  "domain": "search",
  "description": "Cross-language lightweight SDK entrypoints for web-search provider listing and querying without importing the full platform client.",
  "principles": [
    "Expose web search as focused SDK helpers for external research tools, plugin UIs, operator pages, CLIs, sidecars, and automation scripts.",
    "Keep provider listing and search queries directly callable through the existing authenticated /v1/search routes.",
    "Make Search access available through Agent Kit while preserving Discovery as the broader identity, embeddings, and search slice."
  ],
  "routes": [
    "GET /v1/search",
    "GET /v1/search/providers"
  ],
  "capabilities": [
    {
      "name": "query",
      "route": "GET /v1/search",
      "readOnly": true,
      "description": "Run a web search query with optional limit and provider override."
    },
    {
      "name": "providers",
      "route": "GET /v1/search/providers",
      "readOnly": true,
      "description": "List configured search providers."
    }
  ],
  "languages": {
    "typescript": {
      "package": "yunque-client",
      "implementationFiles": [
        "packages/yunque-client/src/search.ts",
        "packages/yunque-client/src/agent-kit.ts"
      ],
      "docs": [
        "packages/yunque-client/README.md",
        "docs/plugins/sdk-typescript.md"
      ],
      "entrypoints": {
        "query": "createSearchClient().search",
        "providers": "createSearchClient().providers"
      }
    },
    "go": {
      "package": "yunque-agent/sdk/go/yunque",
      "implementationFiles": [
        "sdk/go/yunque/yunque.go"
      ],
      "docs": [
        "sdk/go/README.md",
        "docs/plugins/sdk-go.md"
      ],
      "entrypoints": {
        "query": "yunque.WebSearch.Query",
        "providers": "yunque.WebSearch.Providers"
      }
    },
    "python": {
      "package": "yunque",
      "implementationFiles": [
        "sdk/python/yunque/__init__.py"
      ],
      "docs": [
        "sdk/python/README.md",
        "docs/plugins/sdk-python.md"
      ],
      "entrypoints": {
        "query": "yunque.search_sdk.query",
        "providers": "yunque.search_sdk.providers"
      }
    },
    "rust": {
      "package": "yunque-client",
      "implementationFiles": [
        "sdk/rust/src/lib.rs"
      ],
      "docs": [
        "sdk/rust/README.md",
        "docs/plugins/sdk-rust.md"
      ],
      "entrypoints": {
        "query": "SearchClient::query",
        "providers": "SearchClient::providers"
      }
    }
  },
  "overviewDocs": [
    "docs/plugins/sdk-overview.md",
    "docs/plugins/overview.md",
    "docs/plugins/developing.md"
  ]
}
