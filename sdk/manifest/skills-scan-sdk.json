{
  "version": 1,
  "domain": "skills-scan",
  "description": "Cross-language lightweight SDK for refreshing runtime skill discovery without importing the full platform client or broader Skills management slice.",
  "principles": [
    "Expose runtime skill scanning as a focused operator SDK slice for CLIs, sidecars, admin pages, plugins, and automation scripts.",
    "Keep scan refreshes directly callable through the existing authenticated gateway route.",
    "Make SkillsScan available through Agent Kit while preserving a standalone composable facade."
  ],
  "routes": [
    "POST /v1/skills/scan"
  ],
  "capabilities": [
    {
      "name": "scan",
      "route": "POST /v1/skills/scan",
      "readOnly": false,
      "description": "Refresh runtime skill discovery and return scan status."
    }
  ],
  "languages": {
    "typescript": {
      "package": "yunque-client",
      "implementationFiles": [
        "sdk/typescript/src/skills-scan.ts",
        "sdk/typescript/src/agent-kit.ts"
      ],
      "docs": [
        "sdk/typescript/README.md",
        "docs/plugins/sdk-typescript.md"
      ],
      "entrypoints": {
        "scan": "createSkillsScanClient().scan"
      }
    },
    "go": {
      "package": "yunque-agent/sdk/go/yunque",
      "implementationFiles": [
        "sdk/go/yunque/yunque.go"
      ],
      "docs": [
        "sdk/go/README.md",
        "docs/plugins/sdk-go.md"
      ],
      "entrypoints": {
        "scan": "yunque.SkillsScan.Scan"
      }
    },
    "python": {
      "package": "yunque",
      "implementationFiles": [
        "sdk/python/yunque/__init__.py"
      ],
      "docs": [
        "sdk/python/README.md",
        "docs/plugins/sdk-python.md"
      ],
      "entrypoints": {
        "scan": "yunque.skills_scan.scan"
      }
    },
    "rust": {
      "package": "yunque-client",
      "implementationFiles": [
        "sdk/rust/src/lib.rs"
      ],
      "docs": [
        "sdk/rust/README.md",
        "docs/plugins/sdk-rust.md"
      ],
      "entrypoints": {
        "scan": "SkillsScanClient::scan"
      }
    }
  },
  "overviewDocs": [
    "docs/plugins/sdk-overview.md",
    "docs/plugins/overview.md",
    "docs/plugins/developing.md"
  ]
}
