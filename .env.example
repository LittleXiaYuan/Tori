# ╔══════════════════════════════════════════════════════════════╗
# ║  云雀 Agent (Yunque Agent) — Configuration                  ║
# ║  https://github.com/LittleXiaYuan/Tori                     ║
# ╚══════════════════════════════════════════════════════════════╝
#
# ⚠️  PRODUCTION DEPLOYMENT CHECKLIST — 生产部署必改项：
#   1. JWT_SECRET      — 必须替换为强随机字符串: openssl rand -hex 32
#   2. DEFAULT_API_KEY  — 必须替换为安全的 API 密钥
#   3. ALLOWED_ORIGINS  — 禁止使用 *，请指定实际域名
#   4. LLM_API_KEY      — 使用你自己的大模型密钥
#   5. 未配置 sandbox/browser/provider 时，对应功能自动降级禁用
#

# ── Server 服务器 ──
AGENT_ADDR=:9090
# OPEN_BROWSER=false        # 禁用启动时自动打开浏览器 (Docker/服务器部署时设为 false)

# ── LLM Provider 大模型 (必填) ──
LLM_BASE_URL=https://api-ai.gitcode.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=zai-org/GLM-5

# ── Multi-Model Pool 多模型池 (可选) ──
# Fast tier: 快速/便宜模型, 用于分类、摘要、trust review 等轻量任务
# LLM_FAST_URL=https://api-ai.gitcode.com/v1
# LLM_FAST_KEY=
# LLM_FAST_MODEL=zai-org/GLM-4-Flash
#
# Expert tier: 专家/强力模型, 用于复杂推理、代码生成等
# LLM_EXPERT_URL=https://api-ai.gitcode.com/v1
# LLM_EXPERT_KEY=
# LLM_EXPERT_MODEL=zai-org/GLM-4-Plus
#
# Fallback: 主模型不可用时的备选
# LLM_FALLBACK_URL=
# LLM_FALLBACK_KEY=
# LLM_FALLBACK_MODEL=

# ── Database 数据库 (可选, 留空使用内置文件存储) ──
# DATABASE_URL=postgres://yunque:password@localhost:5432/yunque?sslmode=disable

# ── Authentication 认证 ──
# ⚠️  CRITICAL: JWT_SECRET MUST be a cryptographically random string in production!
# Generate: openssl rand -hex 32
# Bad examples (will be rejected): repeating patterns like "C7C7C7...", short strings, "changeme"
# The agent will REFUSE TO START in production if this is weak or a known placeholder.
JWT_SECRET=your-jwt-secret-change-in-production
DEFAULT_TENANT_ID=default
# IMPORTANT: Generate a unique API key for production!
DEFAULT_API_KEY=ya_your-default-api-key

# ── CORS ──
# WARNING: Using * is insecure for production. Specify allowed origins.
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9090
ALLOWED_ORIGINS=*

# ── Rate Limiting 限流 (每分钟每租户请求数) ──
# RATE_LIMIT=60

# ── Embeddings 向量嵌入 (可选, 用于知识库语义搜索) ──
# EMBED_BASE_URL=https://api-ai.gitcode.com/v1
# EMBED_MODEL=text-embedding-3-small
# EMBED_DIMS=1536

# ── Web Search 联网搜索 (可选, 至少配一个即可) ──
# BRAVE_API_KEY=
# TAVILY_API_KEY=
# SEARXNG_URL=http://localhost:8888

# ?? MinerU Document Parsing (optional) ??
# Install CLI first: pip install -U "mineru[core]"
# MINERU_ENABLED=true
# MINERU_BACKEND=cli
# MINERU_COMMAND=mineru
# MINERU_CLI_ARGS=-p {input_file} -o {output_dir} -b pipeline
# MINERU_OUTPUT_DIR=
# MINERU_TIMEOUT_SEC=300

# ── Heartbeat 心跳 (可选, Agent 定期自检) ──
# HEARTBEAT_ENABLED=true
# HEARTBEAT_INTERVAL=30     # 分钟

# ── Self-Iterate 受控自我迭代 (可选) ──
# SELF_ITERATE_ENABLED=true
# SELF_ITERATE_TOKEN_BUDGET=5000
# SELF_ITERATE_MAX_ROUNDS=3
# SELF_ITERATE_COOLDOWN=60  # 分钟
# SELF_ITERATE_AUTO_APPROVE=false

# ── ReAct 推理模式 (可选, 需 Ledger) ──
# 启用后 Planner 使用 Observe→Think→Act 推理循环替代纯工具调用
# 自动记录推理轨迹、支持回溯、经验蒸馏
# REACT_ENABLED=true

# ── 反思评估 (Reflect) ──
# 评估回复质量的模式:
#   strict   = 阻塞式：质量不足时重试（仅限工作/任务类消息）
#   learning = 异步：不阻塞回复，后台评估供学习（推荐，默认）
#   off      = 完全禁用
# REFLECT_MODE=learning
# REFLECT_MODEL=fast  # 评估器用的模型池 key，留空则用主模型

# ── Persona 人设 ──
# PERSONA_DIR=data/persona

# ── Pack Runtime 增量包目录 (可选) ──
# 逗号分隔；每项可以是包含 pack.json 的目录、嵌套目录，或明确的 pack.json 文件。
# 默认只读取仓库内置示例和模板；企业部署可替换为私有 pack 源。
# PACK_CATALOG_SOURCES=packs/official,packs/templates

# ── Federation 联邦 (多 Agent 互联, 可选) ──
# FEDERATION_SECRET=

# ── Channels 消息渠道 (可选, 不需要的留空即可) ──
TELEGRAM_BOT_TOKEN=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
DISCORD_BOT_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_PATH=/webhook/whatsapp
SIGNAL_PHONE_NUMBER=
SIGNAL_CONFIG_DIR=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_WEBHOOK_PATH=/webhook/slack
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# ── WeCom (企业微信) ──
WECOM_CORPID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_AES_KEY=
WECOM_PORT=9880
WECOM_BIND_ADDR=0.0.0.0
WECOM_API_BASE_URL=

# ── DingTalk (钉钉) ──
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_PORT=9881
DINGTALK_BIND_ADDR=0.0.0.0

# ── WeChat Official Account (微信公众号) ──
WECHAT_APPID=
WECHAT_APPSECRET=
WECHAT_TOKEN=
WECHAT_AES_KEY=
WECHAT_PORT=9882
WECHAT_BIND_ADDR=0.0.0.0
WECHAT_API_BASE_URL=

# ── LINE Messaging API ──
LINE_CHANNEL_SECRET=
LINE_CHANNEL_TOKEN=
LINE_PORT=9883
LINE_BIND_ADDR=0.0.0.0

# ── Kook (开黑啦) ──
KOOK_TOKEN=

# ── Satori Protocol (通用IM协议) ──
SATORI_ENDPOINT=http://localhost:5140
SATORI_TOKEN=
SATORI_PORT=9884
SATORI_BIND_ADDR=0.0.0.0
SATORI_PLATFORM=
SATORI_SELF_ID=

# ── TTS/STT (语音合成/识别) ──
TTS_MODEL=tts-1
STT_MODEL=whisper-1

# ── Reverie (内心独白 / 自主思考) ──
# REVERIE_ENABLED=true              # 启用/禁用 Reverie 背景思考
# REVERIE_INTERVAL=30m              # 周期性思考间隔 (默认 30 分钟)
# 主动推送目标: 配置后 Reverie 会将重要思考推送到指定聊天
# 值为渠道对应的 chat_id/channel_id，多目标可用逗号分隔
# REVERIE_TARGET_TELEGRAM=123456789             # Telegram chat_id
# REVERIE_TARGET_FEISHU=oc_xxxxxxxx             # Feishu open_chat_id
# REVERIE_TARGET_DISCORD=123456789              # Discord channel_id
# REVERIE_TARGET_WHATSAPP=86138xxxx@s.whatsapp.net  # WhatsApp JID
# REVERIE_TARGET_SLACK=C0123456789              # Slack channel_id
# REVERIE_TARGET_WECOM=wrkSFfCgAAxxxxxxxx      # WeCom external_userid
# REVERIE_TARGET_DINGTALK=cidXxxxxxxxxxxxx      # DingTalk conversation_id
# REVERIE_TARGET_LINE=Uf12345678xxxx           # LINE user_id or group_id
# REVERIE_TARGET_KOOK=123456789                 # Kook channel_id

# ── Rerank (检索重排序) ──
# JINA_API_KEY=                     # Jina AI Reranker API Key
# JINA_RERANK_MODEL=jina-reranker-v2-base-multilingual
# COHERE_API_KEY=                   # Cohere Reranker API Key (备选)
# COHERE_RERANK_MODEL=rerank-v3.5

# ── Cloud Sandbox 云端沙箱 (E2B, 可选, 优先于本地沙箱) ──
# 配置后自动启用，代码执行和桌面沙箱均走云端，失败时自动回退本地
# SANDBOX_CLOUD_API_KEY=            # E2B API Key (https://e2b.dev)
# SANDBOX_CLOUD_BASE_URL=https://api.e2b.app  # E2B API 地址 (兼容提供商可替换)
# SANDBOX_CLOUD_TEMPLATE=base       # 沙箱模板 (base / desktop 等)
# SANDBOX_CLOUD_TIMEOUT=60s         # 沙箱执行超时 (桌面沙箱固定30分钟)
# 也可通过 Tori-API 代理使用 E2B: 只需配置 TORI_API_BASE_URL + LLM_API_KEY 即可自动启用

# ── Sandbox (代码执行沙箱, 本地) ──
# SANDBOX_DOCKER_ENABLED=false      # 启用Docker沙箱隔离 (需要安装Docker)
# SANDBOX_DOCKER_IMAGE=python:3.12-slim  # 默认Docker镜像
# SANDBOX_DOCKER_POOL_SIZE=2        # 每个镜像预热容器数
# SANDBOX_DOCKER_MAX_CONTAINERS=10  # 最大并发容器数
# SANDBOX_DOCKER_IDLE_TIMEOUT=5m    # 空闲容器回收时间
# SANDBOX_DOCKER_MEMORY=256m        # 容器内存限制
# SANDBOX_DOCKER_CPU=1              # 容器CPU限制
# SANDBOX_DOCKER_PIDS_LIMIT=64      # 进程数限制 (防fork炸弹)
# SANDBOX_DOCKER_NETWORK=false      # 容器网络 (默认禁用)
# SANDBOX_DOCKER_READONLY_ROOTFS=true   # 只读根文件系统
# SANDBOX_DOCKER_NON_ROOT=true      # 以非root用户运行
# SANDBOX_DOCKER_TIMEOUT=30s        # 执行超时
# SANDBOX_DOCKER_IMAGE_PYTHON=python:3.12-slim   # Python镜像
# SANDBOX_DOCKER_IMAGE_JAVASCRIPT=node:20-slim    # Node.js镜像
# SANDBOX_DOCKER_IMAGE_GO=golang:1.22-alpine      # Go镜像
# SANDBOX_DOCKER_IMAGE_SHELL=alpine:latest         # Shell镜像
# SANDBOX_DOCKER_ALLOWED_IMAGES=python:3.12-slim,node:20-slim  # 镜像白名单
# SANDBOX_TIER=family               # 进程沙箱安全级别 (personal/family/public)
# SANDBOX_BASE_DIR=                  # 沙箱工作目录 (默认系统临时目录)

# ── Browser 浏览器自动化 (可选) ──
# BROWSER_HEADLESS=true              # true=无头(服务器), false=弹窗(本机)
# BROWSER_TIMEOUT=30s                # 页面操作超时
# BROWSER_DATA_DIR=data/browser      # Cookie/Session 持久化目录

# ── OCR 文字识别 (可选, 不配也能用 DOM 直接读) ──
# TESSERACT_BIN=tesseract              # Tesseract 路径(留空自动从 PATH 查找)
# 视觉模型 — 最强识别效果(可选, 需要有视觉能力的模型)
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_API_KEY=sk-xxx
# VISION_MODEL=gpt-4o

# ── Docker Compose ──
# REQUIRED: generate with `openssl rand -hex 32` before `docker compose up`.
POSTGRES_PASSWORD=__REPLACE_WITH_STRONG_RANDOM_PASSWORD__
# REQUIRED: generate with `openssl rand -hex 32` — the compose file refuses
# to start if this is left unset or contains a known placeholder.
JWT_SECRET=__REPLACE_WITH_OPENSSL_RAND_HEX_32__
VERSION=0.1.0

# Optional: trust browser extension grant tokens issued by Tori-API
TORI_API_BASE_URL=http://localhost:3000

# ── LoRA 自进化 (可选) ──
# LOCALBRAIN_BASE_MODEL=qwen-3.5-4b     # 本地小模型名称
# VLLM_BASE_URL=http://localhost:8000    # vLLM 推理服务地址
# VLLM_API_KEY=                          # vLLM API Key

# LORA_ADAPTER_DIR=data/adapters         # 适配器权重目录
# TRAINING_OUTPUT_DIR=data/training      # 训练数据导出目录
# TRAINING_COLLECTOR=true                # 是否自动采集训练数据 (false 关闭)
# TRAINING_TENANT_IDS=default            # 租户 ID 列表 (逗号分隔)

# LORA_TRAIN_MODE=auto                   # auto | remote | local
# LORA_TRAIN_API_URL=                    # 远程训练服务地址
# LORA_TRAIN_API_KEY=                    # 远程训练服务 API Key
# LORA_TRAIN_SCRIPT=scripts/lora_train.py  # 本地训练脚本路径
# LORA_TRAIN_TIMEOUT=2h                  # 训练超时时间
# LORA_TRAIN_SEED=42                     # 训练随机种子
# LORA_TRAIN_MAX_SEQ_LENGTH=2048         # 最大序列长度
# LORA_TRAIN_TRUST_REMOTE_CODE=false     # 是否信任模型远程代码
# LORA_TRAIN_TARGET_MODULES=             # LoRA 目标模块 (逗号分隔, 留空自动推断)
