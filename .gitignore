# ── Build outputs ──
*.exe
*.exe~
/agent.exe
/yunque.exe
dist/
yunque-agent-*
yunque-agent.exe

# ── Local training/eval data exports at repo root (never commit) ──
/*.b64
/*.jsonl

# ── Test / coverage outputs ──
# Anchor to repo root so tracked source like scripts/coverage.ps1 isn't swept up.
/coverage
/coverage_*
/coverage.*
/coverage_report*.txt
*.test

# ── Logs & temp files ──
*.log
*.err
*.out
backend.err
backend.out
tmp*.txt
reflog*.txt

# ── Runtime data (generated at runtime, not source code) ──
data/

# ── OS / IDE ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
nul

# ── Legacy docs tooling (VitePress) ──
docs/.vitepress/cache/
docs/.vitepress/dist/
.next/

# ── Generated SDK dependencies ──
packages/yunque-client/node_modules/
packages/yunque-client/.cache/
packages/yunque-client/.turbo/

# ── Frontend (源码在 apps/web/src，构建产物在 apps/web/out/) ──
apps/web/node_modules/
apps/web/.next/
apps/web/out/*
!apps/web/out/.keep
apps/web/.env.local
apps/web/tsconfig.tsbuildinfo
apps/desktop/src-tauri/frontend/

# ── Generated HTML snapshots ──
docs/api-reference.html
internal/controlplane/gateway/dashboard.html

# ── Local MCP smoke-test fixtures (not part of the repo) ──
test-mcp.json

# ── Commit-message staging files (used by HEREDOC-avoiding PowerShell shells) ──
.commit-msg.tmp
.commit-msg-*.tmp

# ── Runtime-generated task snapshots ──
internal/agentcore/task/*/

# ── Runtime-generated sandbox workdirs ──
sandbox_*/
**/sandbox_*/

# ── Environment (keep .env.example, ignore actual .env) ──
.env
!.env.example

# ── Secrets (private keys & certs must never be committed) ──
*.pem
*.key
*.p12
*.pfx
*.crt
# allow public certificates that intentionally live in the repo
!**/certs/*-public.pem
!**/certs/*-public.crt
id_rsa
id_ed25519
*.gpg
*.asc

# ── Competitive analysis (not for public) ──
apps/browser-extension/manus-analysis/

# ── AtomCode local agent memories (personal, never commit) ──
.atomcode/memory.md

# ── Local agent/cache artifacts ──
.atomcode/
.tmp/
.cursor/
.aider*
.continue/
.windsurf/
.copilot/

# ── Tauri/Rust build outputs ──
apps/desktop/src-tauri/target*/
apps/desktop/src-tauri/binaries/*.exe

# ── Next.js build artifacts (never commit) ──
**/.next/
**/out/_next/
apps/desktop/src-tauri/frontend/

# ── Pack release artifacts (built locally by scripts/release-pack.mjs) ──
packs/official/*.yqpack
packs/official/*.yqpack.backup-*

# ── Compiled pack WASM modules (built from module/ source at release time) ──
packs/official/*/module.wasm

# ── Production signing keys (never commit private bytes) ──
.yunque-keys/

# ── Local scratch screenshots (UI captures, not source assets) ──
apps/desktop/desktop-launch-*.png
apps/desktop/desktop-login-*.png
apps/desktop/login-clean-*.png
apps/desktop/packs-page-*.png

# ── Local env backups (may contain secrets) ──
apps/web/.env.local.bak*

# ── Temp TypeScript build info / scratch tsconfigs ──
apps/web/tsconfig*.tmp.*
*.tmp.tsbuildinfo

# AtomCode local-scope configs (machine-specific)
.atomcode/local/

# ── AI assistant / editor tooling artifacts (never publish) ──
.agent-bus/
.agents/
.atomcode/
.claude/
.cursor/

# ── Local scratch docs dir (docs/ IS published; doc/ is local-only) ──
/doc/

# ── Playwright MCP captures & local scratch artifacts ──
.playwright-mcp/
/logo-preview.html
/splash-current.png
.tmp-*
/*.b64
