*.exe
*.exe~
tori
tori_*
/agent
/agent.exe
/yunque.exe
dist/
yunque-agent-*
yunque-agent.exe

# ── Test / coverage outputs ──
coverage
coverage_*
coverage.*
coverage_report*.txt
*.test

# ── Logs & temp files ──
*.log
*.err
*.out
backend.err
backend.out
tmp*.txt
reflog*.txt

# ── Runtime data (generated at runtime, not source code) ──
data/

# ── OS / IDE ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
nul

# ── Go ──
vendor/

# ── Legacy frontend (已归档) ──
web/
docs/node_modules/
docs/.vitepress/cache/
docs/.vitepress/dist/
.next/

# ── Generated SDK dependencies ──
sdk/typescript/node_modules/
sdk/typescript/.cache/
sdk/typescript/.turbo/

# ── Frontend (源码在 heroui-web/src，构建产物在 heroui-web/out/) ──
heroui-web/node_modules/
heroui-web/.next/
heroui-web/out/*
!heroui-web/out/.keep
heroui-web/.env.local
heroui-web/tsconfig.tsbuildinfo
desktop/src-tauri/frontend/

# ── Generated HTML snapshots ──
docs/api-reference.html
internal/controlplane/gateway/dashboard.html

# ── Local MCP smoke-test fixtures (not part of the repo) ──
test-mcp.json

# ── Commit-message staging files (used by HEREDOC-avoiding PowerShell shells) ──
.commit-msg.tmp
.commit-msg-*.tmp

# ── Runtime-generated task snapshots ──
internal/agentcore/task/*/

# ── Runtime-generated sandbox workdirs ──
sandbox_*/
**/sandbox_*/

# ── Environment (keep .env.example, ignore actual .env) ──
.env
!.env.example

# ── Secrets (private keys & certs must never be committed) ──
*.pem
*.key
*.p12
*.pfx
*.crt
# allow public certificates that intentionally live in the repo
!**/certs/*-public.pem
!**/certs/*-public.crt
id_rsa
id_ed25519
*.gpg
*.asc

# ── Internal dev docs (not for public) ──
doc/

# ── Competitive analysis (not for public) ──
browser-extension/manus-analysis/

# ── AtomCode local agent memories (personal, never commit) ──
.atomcode/memory.md

# ── Local agent/cache artifacts ──
.atomcode/
.tmp/

# ── Tauri/Rust build outputs ──
desktop/src-tauri/target*/
