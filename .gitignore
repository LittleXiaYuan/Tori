# ── Build outputs ──
*.exe
*.exe~
tori
tori_*
agent
dist/

# ── Logs & temp files ──
*.log
tmp*.txt
reflog*.txt

# ── Runtime data (generated at runtime, not source code) ──
data/

# ── OS / IDE ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
nul

# ── Go ──
vendor/

# ── Legacy frontend (已归档) ──
web/
docs/node_modules/
docs/.vitepress/cache/
docs/.vitepress/dist/
.next/

# ── Frontend source (独立仓库发布，后端仅保留 embed.go + 占位 out/) ──
heroui-web/*
!heroui-web/embed.go
!heroui-web/out/
heroui-web/out/*
!heroui-web/out/placeholder.html

# ── Runtime-generated task snapshots ──
internal/agentcore/task/*/

# ── Environment (keep .env.example, ignore actual .env) ──
.env
!.env.example

# ── Internal dev docs (not for public) ──
doc/

