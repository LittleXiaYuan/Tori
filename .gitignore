# ── Build outputs ──
*.exe
*.exe~
tori
tori_*
/agent
dist/
yunque-agent-*
yunque-agent.exe

# ── Logs & temp files ──
*.log
*.err
*.out
backend.err
backend.out
tmp*.txt
reflog*.txt

# ── Runtime data (generated at runtime, not source code) ──
data/

# ── OS / IDE ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
nul

# ── Go ──
vendor/

# ── Legacy frontend (已归档) ──
web/
docs/node_modules/
docs/.vitepress/cache/
docs/.vitepress/dist/
.next/

# ── Frontend (源码在 heroui-web/src，构建产物在 heroui-web/out/) ──
heroui-web/node_modules/
heroui-web/.next/
heroui-web/out/
heroui-web/.env.local
heroui-web/tsconfig.tsbuildinfo

# ── Local MCP smoke-test fixtures (not part of the repo) ──
test-mcp.json

# ── Commit-message staging files (used by HEREDOC-avoiding PowerShell shells) ──
.commit-msg.tmp

# ── Runtime-generated task snapshots ──
internal/agentcore/task/*/

# ── Environment (keep .env.example, ignore actual .env) ──
.env
!.env.example

# ── Secrets (private keys & certs must never be committed) ──
*.pem
*.key
*.p12
*.pfx
*.crt
# allow public certificates that intentionally live in the repo
!**/certs/*-public.pem
!**/certs/*-public.crt
id_rsa
id_ed25519
*.gpg
*.asc

# ── Internal dev docs (not for public) ──
doc/

# ── Competitive analysis (not for public) ──
browser-extension/manus-analysis/


