{
  "manifest_version": 3,
  "name": "Yunque Browser Connector",
  "description": "Connect your browser to Yunque Agent for intelligent browsing automation.",
  "version": "0.3.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Yunque Browser Connector",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "debugger",
    "scripting",
    "activeTab",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "js": [
        "content.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ]
}
