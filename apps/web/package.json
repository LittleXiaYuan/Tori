{
  "name": "yunque-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --port 3001",
    "build": "next build && node -e \"require('fs').writeFileSync('out/.keep', 'placeholder for Go embed when the Next.js static export has not been built\\n')\"",
    "start": "next start --port 3001",
    "typecheck": "tsc --noEmit",
    "check:sdk-boundaries": "node scripts/check-sdk-boundaries.mjs",
    "check:pack-usability": "node ../../scripts/check-pack-usability.mjs --strict",
    "test": "node scripts/check-sdk-boundaries.mjs && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@heroui-pro/react": "^1.0.0-beta.6",
    "@heroui/react": "^3.0.1",
    "@heroui/styles": "^3.0.1",
    "@number-flow/react": "^0.6.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/extensions": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "^3.27.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.7.0",
    "marked": "^18.0.5",
    "motion": "^12.42.0",
    "next": "^16.2.3",
    "react": "^19.2.4",
    "react-aria-components": "^1.19.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.9.0",
    "rehype-highlight": "^7.0.2",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "yunque-client": "file:../../packages/yunque-client"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
  }
}
