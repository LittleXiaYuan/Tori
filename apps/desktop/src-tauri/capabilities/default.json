{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Yunque Desktop. The Go sidecar is spawned directly via std::process so we can control CREATE_NEW_PROCESS_GROUP / CTRL_BREAK_EVENT for graceful shutdown; we therefore do NOT need shell:allow-spawn / shell:allow-execute permissions here.",
  "windows": ["main", "floating-ball", "floating-panel", "selection-popup"],
  "remote": {
    "urls": ["http://localhost:3001", "http://127.0.0.1:3001", "http://127.0.0.1:9090"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-outer-position",
    "core:window:allow-is-visible",
    "core:window:allow-set-position",
    "core:window:allow-primary-monitor",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text"
  ]
}
