{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Yunque Agent",
  "version": "0.1.0",
  "identifier": "com.yunque.agent",
  "build": {
    "frontendDist": "./frontend",
    "devUrl": "http://localhost:3001"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "云雀 Agent",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "hiddenTitle": true,
        "visible": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' http://127.0.0.1:9090 ws://127.0.0.1:9090 http://localhost:9090 ws://localhost:9090 http://ipc.localhost https://ipc.localhost ipc:; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; media-src 'self' blob:; frame-ancestors 'none'; object-src 'none'; base-uri 'self'",
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/yunque-agent"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGN0M5NjNEQkZDMTcwOUQKUldTZGNNRy9QWlo4djBxYk55aWRpd2YyNDVVTnRSMENYQnlTZ20zdHRDdXptMHo2MmM4WFd1WjgK",
      "endpoints": [
        "https://REPLACE-WITH-YOUR-CDN.example.com/yunque/updater/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
